generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum PlanType {
  FREE
  PREMIUM
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String?
  authProviderId   String?   @unique
  role             Role      @default(USER)
  planType         PlanType  @default(FREE)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  Profile          Profile?
  AuditLogs        AuditLog[]
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  displayName     String?
  avatarUrl       String?
  preferencesJson Json?
  
  User            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Sport {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  
  Teams           Team[]
  Games           Game[]
  TeamMetrics     TeamMetric[]
  PlayerMetrics   PlayerMetric[]
  ResearchReports ResearchReport[]
  Picks           Pick[]
}

model Team {
  id              String   @id @default(cuid())
  sportId         String
  name            String
  abbreviation    String
  conference      String?
  division        String?
  metadataJson    Json?

  Sport           Sport    @relation(fields: [sportId], references: [id])
  Players         Player[]
  HomeGames       Game[]   @relation("HomeTeam")
  AwayGames       Game[]   @relation("AwayTeam")
  TeamMetrics     TeamMetric[]
  Injuries        Injury[]
}

model Player {
  id              String   @id @default(cuid())
  teamId          String
  name            String
  position        String?
  status          String?
  metadataJson    Json?

  Team            Team     @relation(fields: [teamId], references: [id])
  PlayerMetrics   PlayerMetric[]
  Injuries        Injury[]
}

model Game {
  id              String   @id @default(cuid())
  sportId         String
  externalId      String?  @unique
  homeTeamId      String
  awayTeamId      String
  gameTime        DateTime
  status          String
  venue           String?
  season          String?
  weekOrRound     String?
  metadataJson    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  Sport           Sport    @relation(fields: [sportId], references: [id])
  HomeTeam        Team     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  AwayTeam        Team     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  
  GameContext     GameContext?
  Injuries        Injury[]
  OddsSnapshots   OddsSnapshot[]
  LineMovements   LineMovement[]
  ResearchReports ResearchReport[]
  ModelScores     ModelScore[]
  Picks           Pick[]
}

model GameContext {
  id              String   @id @default(cuid())
  gameId          String   @unique
  weatherJson     Json?
  travelJson      Json?
  restJson        Json?
  situationalJson Json?
  newsSummary     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  Game            Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model Injury {
  id              String   @id @default(cuid())
  playerId        String
  gameId          String?
  teamId          String
  status          String
  injuryType      String?
  notes           String?
  source          String?
  updatedAt       DateTime @updatedAt

  Player          Player   @relation(fields: [playerId], references: [id])
  Team            Team     @relation(fields: [teamId], references: [id])
  Game            Game?    @relation(fields: [gameId], references: [id])
}

model OddsSnapshot {
  id              String   @id @default(cuid())
  gameId          String
  sportsbook      String
  marketType      String
  lineValue       Float?
  price           Float
  timestamp       DateTime @default(now())

  Game            Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model LineMovement {
  id              String   @id @default(cuid())
  gameId          String
  marketType      String
  openLine        Float?
  currentLine     Float?
  bestLine        Float?
  marketConsensus Float?
  closingLine     Float?
  movementJson    Json?
  updatedAt       DateTime @updatedAt

  Game            Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model TeamMetric {
  id              String   @id @default(cuid())
  teamId          String
  sportId         String
  periodScope     String
  metricsJson     Json
  updatedAt       DateTime @updatedAt

  Team            Team     @relation(fields: [teamId], references: [id])
  Sport           Sport    @relation(fields: [sportId], references: [id])
}

model PlayerMetric {
  id              String   @id @default(cuid())
  playerId        String
  sportId         String
  periodScope     String
  metricsJson     Json
  updatedAt       DateTime @updatedAt

  Player          Player   @relation(fields: [playerId], references: [id])
  Sport           Sport    @relation(fields: [sportId], references: [id])
}

model ResearchReport {
  id              String   @id @default(cuid())
  gameId          String
  sportId         String
  reportType      String
  rawDataJson     Json
  aiSummary       String?
  aiRiskSummary   String?
  aiCounterpoints String?
  createdAt       DateTime @default(now())

  Game            Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  Sport           Sport    @relation(fields: [sportId], references: [id])
}

model ModelScore {
  id                    String   @id @default(cuid())
  gameId                String
  marketType            String
  selection             String
  projectedLine         Float?
  marketLine            Float?
  edgeValue             Float?
  confidenceScore       Float?
  volatilityScore       Float?
  riskScore             Float?
  noBetFlag             Boolean  @default(false)
  scoringBreakdownJson  Json?
  createdAt             DateTime @default(now())

  Game                  Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

enum VisibilityType {
  ADMIN_ONLY
  FREE
  PREMIUM
  TEASER
}

model Pick {
  id              String   @id @default(cuid())
  gameId          String
  sportId         String
  marketType      String
  selection       String
  lineTaken       Float?
  oddsTaken       Int?
  confidenceScore Float?
  edgeValue       Float?
  riskScore       Float?
  packageType     String?
  pickTier        String?
  visibilityType  VisibilityType @default(ADMIN_ONLY)
  status          String   @default("PENDING") // PENDING, PUBLISHED, SETTLED
  reasoningShort  String?
  reasoningLong   String?
  riskNotes       String?
  counterCase     String?
  isFeatured      Boolean  @default(false)
  publishedAt     DateTime?
  settledAt       DateTime?
  result          String?  // WIN, LOSS, PUSH
  unitsRisked     Float?
  unitsWonLost    Float?

  Game            Game     @relation(fields: [gameId], references: [id])
  Sport           Sport    @relation(fields: [sportId], references: [id])
  ParlayLegs      ParlayLeg[]
  PackageItems    PackageItem[]
}

model Parlay {
  id              String   @id @default(cuid())
  name            String
  packageType     String?
  sportScope      String?
  legCount        Int
  combinedOdds    Int?
  confidenceScore Float?
  riskScore       Float?
  summary         String?
  visibilityType  VisibilityType @default(ADMIN_ONLY)
  publishedAt     DateTime?
  settledAt       DateTime?
  result          String?
  unitsRisked     Float?
  unitsWonLost    Float?

  ParlayLegs      ParlayLeg[]
  PackageItems    PackageItem[]
}

model ParlayLeg {
  id              String   @id @default(cuid())
  parlayId        String
  pickId          String
  orderIndex      Int

  Parlay          Parlay   @relation(fields: [parlayId], references: [id], onDelete: Cascade)
  Pick            Pick     @relation(fields: [pickId], references: [id])
}

model Package {
  id              String   @id @default(cuid())
  packageName     String
  packageType     String
  sportScope      String?
  visibilityType  VisibilityType @default(ADMIN_ONLY)
  summary         String?
  publishedAt     DateTime?
  status          String   @default("DRAFT")

  PackageItems    PackageItem[]
}

model PackageItem {
  id              String   @id @default(cuid())
  packageId       String
  itemType        String   // PICK or PARLAY
  pickId          String?
  parlayId        String?
  orderIndex      Int

  Package         Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  Pick            Pick?    @relation(fields: [pickId], references: [id])
  Parlay          Parlay?  @relation(fields: [parlayId], references: [id])
}

model PerformanceDaily {
  id              String   @id @default(cuid())
  date            DateTime @unique
  category        String
  wins            Int      @default(0)
  losses          Int      @default(0)
  pushes          Int      @default(0)
  winPct          Float?
  unitsWonLost    Float?
  roi             Float?
  yieldPct        Float?
}

model PerformanceAggregate {
  id              String   @id @default(cuid())
  periodType      String
  category        String
  sportId         String?
  packageType     String?
  wins            Int      @default(0)
  losses          Int      @default(0)
  pushes          Int      @default(0)
  winPct          Float?
  unitsWonLost    Float?
  roi             Float?
  clvMetricsJson  Json?
  updatedAt       DateTime @updatedAt
}

model AdminSetting {
  id              String   @id @default(cuid())
  key             String   @unique
  valueJson       Json
  updatedAt       DateTime @updatedAt
}

model JobRun {
  id              String   @id @default(cuid())
  jobName         String
  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  status          String
  logText         String?
}

model AuditLog {
  id              String   @id @default(cuid())
  adminUserId     String
  actionType      String
  entityType      String
  entityId        String
  detailsJson     Json?
  createdAt       DateTime @default(now())

  User            User     @relation(fields: [adminUserId], references: [id])
}

model SportsbookLink {
  id                String   @id @default(cuid())
  sportsbookName    String
  sport             String
  league            String?
  teamEventMapping  String?
  marketType        String?
  deepLinkUrl       String
  affiliateTag      String?
  stateRestrictions String?
  isActive          Boolean  @default(true)
}
